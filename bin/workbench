#!/usr/bin/env bash
set -euo pipefail

WORKBENCH_ROOT="${WORKBENCH_ROOT:-$HOME/.workbench}"

# Resolve path to the compiled wb CLI (packages/cli/dist/index.js).
# Works both in-repo (bin/ next to packages/) and post-install
# (~/.workbench/bin/ next to ~/.workbench/packages/).
_SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
WB_CLI="${WB_CLI:-$_SCRIPT_DIR/../packages/cli/dist/index.js}"

_run_indexer() {
  if ! command -v node >/dev/null 2>&1; then
    echo "Error: Node.js is required for indexer commands" >&2
    echo "  Install Node.js >= 20 from https://nodejs.org" >&2
    exit 1
  fi
  if [ ! -f "$WB_CLI" ]; then
    echo "Error: Workbench indexer not built." >&2
    echo "  Run from the workbench repo root:" >&2
    echo "    pnpm install && pnpm run build" >&2
    exit 1
  fi
  exec node "$WB_CLI" "$@"
}

cmd_doctor() {
  echo "Workbench Health Check"
  echo "======================"
  echo ""
  
  local status=0
  
  # Check root exists
  if [ -d "$WORKBENCH_ROOT" ]; then
    echo "✓ Workbench root: $WORKBENCH_ROOT"
  else
    echo "✗ Workbench root not found: $WORKBENCH_ROOT"
    status=1
  fi
  
  # Check required directories
  for dir in skills hooks memory templates .tmp; do
    if [ -d "$WORKBENCH_ROOT/$dir" ]; then
      echo "✓ Directory: $dir/"
    else
      echo "✗ Missing: $dir/"
      status=1
    fi
  done
  
  # Check key files
  for file in config.yaml memory/MEMORY.md; do
    if [ -f "$WORKBENCH_ROOT/$file" ]; then
      echo "✓ File: $file"
    else
      echo "⚠ Missing: $file"
    fi
  done
  
  # Check skills
  for skill in skillify session-extract dream; do
    if [ -f "$WORKBENCH_ROOT/skills/$skill/SKILL.md" ]; then
      echo "✓ Skill: $skill"
    else
      echo "✗ Missing skill: $skill"
      status=1
    fi
  done
  
  # Check optional tools
  echo ""
  echo "Optional Dependencies:"
  for tool in jq yq mempalace; do
    if command -v "$tool" >/dev/null 2>&1; then
      echo "✓ $tool ($(command -v "$tool"))"
    else
      echo "○ $tool (not installed)"
    fi
  done
  
  # Check Copilot hooks if installed
  if [ -d "$WORKBENCH_ROOT/hooks/copilot" ]; then
    echo ""
    echo "Copilot Hooks:"
    for script in session-start.sh post-tool-use.sh session-end.sh; do
      if [ -x "$WORKBENCH_ROOT/hooks/copilot/$script" ]; then
        echo "✓ $script (executable)"
      else
        echo "⚠ $script (not executable)"
      fi
    done
  fi
  
  echo ""
  if [ $status -eq 0 ]; then
    echo "Status: ✓ Healthy"
  else
    echo "Status: ✗ Issues found"
  fi
  
  return $status
}

cmd_print_steering_doc() {
  if [ -f "$WORKBENCH_ROOT/templates/steering-doc-template.md" ]; then
    cat "$WORKBENCH_ROOT/templates/steering-doc-template.md"
  else
    echo "Error: steering-doc-template.md not found" >&2
    exit 1
  fi
}

cmd_install_copilot() {
  local target="${1:-.}"
  
  if [ ! -d "$target" ]; then
    echo "Error: Target directory does not exist: $target" >&2
    exit 1
  fi
  
  echo "Installing Copilot hooks to: $target/.github/hooks/"
  
  mkdir -p "$target/.github/hooks/copilot"
  cp -r "$WORKBENCH_ROOT/hooks/copilot/"* "$target/.github/hooks/copilot/"
  chmod +x "$target/.github/hooks/copilot/"*.sh
  
  echo ""
  echo "✓ Hooks installed"
  echo ""
  echo "Next steps:"
  echo "  1. For cloud agent: Commit .github/hooks/ to your default branch"
  echo "  2. For CLI: Hooks work immediately from current directory"
  echo "  3. Add steering doc:"
  echo "     workbench print steering-doc >> .github/copilot-instructions.md"
  echo "  4. Optional: Install skills to Copilot:"
  echo "     workbench copilot skills [--global]"
  echo ""
}

cmd_copilot_skills() {
  local scope="project"
  if [ "${1:-}" = "--global" ] || [ "${1:-}" = "-g" ]; then
    scope="global"
  fi
  
  "$WORKBENCH_ROOT/bin/workbench-copilot-skills" "$scope"
}

cmd_mempalace_status() {
  if command -v mempalace >/dev/null 2>&1; then
    echo "MemPalace: installed ($(command -v mempalace))"
    mempalace status 2>/dev/null || echo "  (status command not available)"
  else
    echo "MemPalace: not installed"
    echo ""
    echo "To enable MemPalace integration:"
    echo "  1. Set integrations.mempalace.enabled: true in config.yaml"
    echo "  2. It will auto-install on first use"
    echo "  Or install manually: https://github.com/MemPalace/mempalace"
  fi
}

cmd_indexer_enable() {
  local repo_root="${1:-}"

  # 1. Find repo root
  if [ -z "$repo_root" ]; then
    if [ -f "$(pwd)/packages/mcp/src/index.ts" ]; then
      repo_root="$(pwd)"
    elif [ -f "$WORKBENCH_ROOT/indexer.json" ]; then
      repo_root="$(python3 -c "import json,sys; d=json.load(open(sys.argv[1])); print(d.get('repoRoot',''))" "$WORKBENCH_ROOT/indexer.json" 2>/dev/null)"
    fi
  fi

  # Try common locations
  if [ -z "$repo_root" ]; then
    for candidate in \
        "$HOME/workbench" \
        "$HOME/projects/workbench" \
        "$HOME/code/workbench" \
        "$HOME/Desktop/workbench" \
        "$HOME/Desktop/Pasha/workbench"; do
      if [ -f "$candidate/packages/mcp/src/index.ts" ]; then
        repo_root="$candidate"
        break
      fi
    done
  fi

  if [ -z "$repo_root" ]; then
    echo "Error: Could not find the workbench repo. Pass the path as an argument:" >&2
    echo "  workbench indexer enable /path/to/workbench" >&2
    exit 1
  fi

  # 2. Verify required files
  if [ ! -f "$repo_root/packages/mcp/src/index.ts" ]; then
    echo "Error: $repo_root/packages/mcp/src/index.ts not found" >&2
    exit 1
  fi
  if [ ! -f "$repo_root/packages/core/loader.mjs" ]; then
    echo "Error: $repo_root/packages/core/loader.mjs not found" >&2
    exit 1
  fi

  # 3. Generate ~/.workbench/bin/wb-mcp wrapper
  local wb_mcp="$WORKBENCH_ROOT/bin/wb-mcp"
  printf '#!/usr/bin/env bash\n# Generated by: workbench indexer enable\n# Workbench indexer MCP server launcher\nexec node \\\n  --experimental-strip-types \\\n  --experimental-loader "%s/packages/core/loader.mjs" \\\n  "%s/packages/mcp/src/index.ts"\n' \
    "$repo_root" "$repo_root" > "$wb_mcp"
  chmod +x "$wb_mcp"

  # 4. Save repo root for future re-runs
  echo "{\"repoRoot\":\"$repo_root\"}" > "$WORKBENCH_ROOT/indexer.json"

  # 5. Edit ~/.claude/.mcp.json (create if missing)
  local mcp_json="$HOME/.claude/.mcp.json"
  python3 - "$mcp_json" << 'PYEOF'
import json, sys, os

path = sys.argv[1]
os.makedirs(os.path.dirname(path), exist_ok=True)
data = {}
if os.path.exists(path):
    with open(path) as f:
        data = json.load(f)
if "mcpServers" not in data:
    data["mcpServers"] = {}
data["mcpServers"]["workbench-indexer"] = {
    "command": "wb-mcp",
    "disabled": False,
    "autoApprove": ["search_code", "get_indexing_status"]
}
with open(path, "w") as f:
    json.dump(data, f, indent=2)
    f.write("\n")
PYEOF

  echo "✓ wb-mcp wrapper written to $wb_mcp"
  echo "✓ workbench-indexer added to $HOME/.claude/.mcp.json"
  echo ""
  echo "Next steps:"
  echo "  1. Run \`wb index\` in your project (downloads model + grammars on first run, ~400 MB)"
  echo "  2. Restart Claude Code to load the new MCP server"
  echo "  3. In your project, ask Claude: \"index this codebase\" to build the index"
}

cmd_indexer_disable() {
  local mcp_json="$HOME/.claude/.mcp.json"
  if [ ! -f "$mcp_json" ]; then
    echo "Indexer is not configured — run 'workbench indexer enable' first."
    exit 1
  fi

  local result
  result="$(python3 - "$mcp_json" << 'PYEOF'
import json, sys

path = sys.argv[1]
with open(path) as f:
    data = json.load(f)
if "workbench-indexer" not in data.get("mcpServers", {}):
    print("NOT_CONFIGURED")
    sys.exit(0)
data["mcpServers"]["workbench-indexer"]["disabled"] = True
with open(path, "w") as f:
    json.dump(data, f, indent=2)
    f.write("\n")
print("OK")
PYEOF
)"

  if [ "$result" = "NOT_CONFIGURED" ]; then
    echo "Indexer is not configured — run 'workbench indexer enable' first."
    exit 1
  fi

  echo "✓ workbench-indexer disabled in $HOME/.claude/.mcp.json"
  echo "Restart Claude Code to apply."
  echo "Run 'workbench indexer enable' to re-enable."
}

cmd_indexer_status() {
  echo "Workbench Indexer Status"
  echo "═════════════════════════"

  # 1. MCP registration
  local mcp_json="$HOME/.claude/.mcp.json"
  if [ ! -f "$mcp_json" ]; then
    echo "MCP server:     ✗ Not registered"
  else
    local mcp_status
    mcp_status="$(python3 - "$mcp_json" << 'PYEOF'
import json, sys
try:
    with open(sys.argv[1]) as f:
        data = json.load(f)
    entry = data.get("mcpServers", {}).get("workbench-indexer")
    if entry is None:
        print("NOT_REGISTERED")
    elif entry.get("disabled"):
        print("DISABLED")
    else:
        print("ACTIVE")
except Exception:
    print("NOT_REGISTERED")
PYEOF
)"
    case "$mcp_status" in
      ACTIVE)          echo "MCP server:     ✓ Registered and active" ;;
      DISABLED)        echo "MCP server:     ⚠ Registered but disabled" ;;
      NOT_REGISTERED)  echo "MCP server:     ✗ Not registered" ;;
    esac
  fi

  # 2. Model + grammars
  local grammar="$WORKBENCH_ROOT/grammars/tree-sitter-python.wasm"
  if [ -f "$grammar" ] && find "$WORKBENCH_ROOT/models" -name "*.onnx" -maxdepth 6 2>/dev/null | grep -q .; then
    echo "Model/grammars: ✓ Ready"
  else
    echo "Model/grammars: ✗ Not ready — run: wb index (triggers auto-setup)"
  fi

  # 3. Project index
  local cwd_hash
  cwd_hash="$(printf '%s' "$(pwd)" | python3 -c "import sys,hashlib; print(hashlib.sha256(sys.stdin.buffer.read()).hexdigest()[:12])")"
  local stats_file="$WORKBENCH_ROOT/$cwd_hash/stats.json"

  if [ -f "$stats_file" ]; then
    python3 - "$stats_file" << 'PYEOF'
import json, sys
from datetime import datetime, timezone
path = sys.argv[1]
try:
    with open(path) as f:
        stats = json.load(f)
    chunks = stats.get("chunkCount", "?")
    ts = stats.get("lastIndexedAt", 0)
    if ts:
        dt = datetime.fromtimestamp(ts / 1000, tz=timezone.utc)
        diff = datetime.now(timezone.utc) - dt
        secs = diff.total_seconds()
        if secs < 3600:
            age = f"{int(secs / 60)} minutes ago"
        elif secs < 86400:
            age = f"{int(secs / 3600)} hours ago"
        else:
            age = f"{int(secs / 86400)} days ago"
        print(f"Project index:  ✓ {chunks} chunks (last indexed: {age})")
    else:
        print(f"Project index:  ✓ {chunks} chunks")
except Exception:
    print("Project index:  ⚠ Stats file malformed")
PYEOF
  else
    echo "Project index:  ○ No index for this project yet"
  fi

  echo ""
  echo "Project:  $(pwd)"
  echo "Index at: $WORKBENCH_ROOT/$cwd_hash/"
}

cmd_init() {
  if [ -d "$WORKBENCH_ROOT" ]; then
    echo "Workbench already initialized at: $WORKBENCH_ROOT"
    exit 1
  fi
  
  echo "Initializing workbench at: $WORKBENCH_ROOT"
  
  # Find install.sh relative to this script
  local script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
  
  if [ -f "$script_dir/install.sh" ]; then
    "$script_dir/install.sh" "$WORKBENCH_ROOT"
  else
    echo "Error: install.sh not found" >&2
    exit 1
  fi
}

# Main command dispatcher
case "${1:-}" in
  doctor)
    cmd_doctor
    ;;
  print)
    shift
    case "${1:-}" in
      steering-doc)
        cmd_print_steering_doc
        ;;
      *)
        echo "Usage: workbench print steering-doc" >&2
        exit 1
        ;;
    esac
    ;;
  install)
    shift
    case "${1:-}" in
      copilot)
        shift
        cmd_install_copilot "${1:-.}"
        ;;
      *)
        echo "Usage: workbench install copilot [target_dir]" >&2
        exit 1
        ;;
    esac
    ;;
  copilot)
    shift
    case "${1:-}" in
      skills)
        shift
        cmd_copilot_skills "$@"
        ;;
      *)
        echo "Usage: workbench copilot skills [--global]" >&2
        exit 1
        ;;
    esac
    ;;
  mempalace)
    shift
    case "${1:-}" in
      status)
        cmd_mempalace_status
        ;;
      *)
        echo "Usage: workbench mempalace status" >&2
        exit 1
        ;;
    esac
    ;;
  init)
    cmd_init
    ;;
  index|search|clear)
    _run_indexer "$@"
    ;;
  indexer)
    shift
    case "${1:-}" in
      enable)
        shift
        cmd_indexer_enable "${1:-}"
        ;;
      disable)
        cmd_indexer_disable
        ;;
      status)
        cmd_indexer_status
        ;;
      *)
        echo "Usage: workbench indexer <enable|disable|status>" >&2
        echo "  enable [path]  Register MCP server with Claude Code" >&2
        echo "  disable        Disable MCP server (preserves config)" >&2
        echo "  status         Show MCP registration + index state" >&2
        exit 1
        ;;
    esac
    ;;
  *)
    echo "Workbench - Portable agent enhancement toolkit"
    echo ""
    echo "Usage:"
    echo "  workbench init                      Initialize workbench"
    echo "  workbench doctor                    Check installation health"
    echo "  workbench print steering-doc        Print steering doc snippet"
    echo "  workbench install copilot [dir]     Install Copilot hooks"
    echo "  workbench copilot skills [--global] Install skills to Copilot"
    echo "  workbench mempalace status          Check MemPalace status"
    echo ""
    echo "Indexer MCP setup:"
    echo "  workbench indexer enable [path]     Register indexer MCP with Claude Code"
    echo "  workbench indexer disable           Disable indexer MCP"
    echo "  workbench indexer status            Show MCP registration + index state"
    echo ""
    echo "Indexer (requires Node.js):"
    echo "  workbench index [path]              Index codebase"
    echo "  workbench status                    Show indexer status"
    echo "  workbench search <query>            Search the index"
    echo "  workbench clear                     Clear the index"
    echo ""
    exit 1
    ;;
esac
