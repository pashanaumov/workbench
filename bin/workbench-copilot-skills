#!/usr/bin/env bash
set -euo pipefail

# Workbench installer for GitHub Copilot
# Installs workbench skills to Copilot's skills directory
# Compatible with: npx skills add

WORKBENCH_ROOT="${WORKBENCH_ROOT:-$HOME/.workbench}"
SCOPE="${1:-project}"  # project or global

if [ "$SCOPE" = "global" ]; then
  COPILOT_SKILLS="$HOME/.copilot/skills"
else
  COPILOT_SKILLS=".agents/skills"
fi

echo "Installing workbench skills to Copilot..."
echo "Scope: $SCOPE"
echo "Target: $COPILOT_SKILLS"
echo ""

# Ensure workbench is installed
if [ ! -d "$WORKBENCH_ROOT" ]; then
  echo "Error: Workbench not found at $WORKBENCH_ROOT"
  echo "Run: curl -fsSL https://raw.githubusercontent.com/pashanaumov/workbench/main/install.sh | bash"
  exit 1
fi

# Create Copilot skills directory
mkdir -p "$COPILOT_SKILLS"

# Symlink workbench skills
for skill_dir in "$WORKBENCH_ROOT/skills"/*; do
  if [ -d "$skill_dir" ] && [ -f "$skill_dir/SKILL.md" ]; then
    skill_name=$(basename "$skill_dir")
    target="$COPILOT_SKILLS/$skill_name"
    
    if [ -e "$target" ]; then
      echo "  ○ $skill_name (already exists)"
    else
      ln -s "$skill_dir" "$target"
      echo "  ✓ $skill_name"
    fi
  fi
done

echo ""
echo "✓ Workbench skills installed to Copilot"
echo ""
echo "Skills available:"
echo "  /skillify - Capture workflows as reusable skills"
echo "  /session-extract - Extract structured session notes"
echo "  /dream - Consolidate notes into long-term memory"
echo "  /workbench - Configure workbench settings"
echo ""
echo "Next steps:"
echo "  1. Install hooks: workbench install copilot"
echo "  2. Add steering doc: workbench print steering-doc >> .github/copilot-instructions.md"
echo ""
